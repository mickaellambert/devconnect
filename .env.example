# ─────────────────────────────────────────────────────────────────
# Modèle de fichier .env pour DevConnect
# ─────────────────────────────────────────────────────────────────
# Copie ce fichier sous le nom `.env` (commande : cp .env.example .env)
# puis remplis les valeurs. Le fichier `.env` n'est PAS commité (cf. .gitignore).
# ─────────────────────────────────────────────────────────────────

# Atelier 1 — port du serveur
PORT=4000

# Atelier 3 — credentials du serveur SMTP (Ethereal pour la formation)
# Crée ton compte sur https://ethereal.email/create puis recopie ici les valeurs.
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Pour préparer la suite (J3 : Prisma + SQLite, J4 : JWT)
# Pas utilisés au J2, à laisser vides pour l'instant.
DATABASE_URL=file:./dev.db
JWT_SECRET=remplace-moi-en-prod
